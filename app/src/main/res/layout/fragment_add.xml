<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yangi Talaba Qo'shish"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"
            android:background="#1A237E"/>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ism"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etFirstName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Talaba ismini kiriting"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1A237E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Familiya"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etLastName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Talaba familiyasini kiriting"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1A237E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guruh"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masalan: CS-21"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1A237E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Baho (0-100)"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etGrade"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masalan: 85.5"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="#1A237E"/>

                <!-- Tugmalar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bekor"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#9E9E9E"
                        android:textColor="#FFFFFF"/>

                    <Button
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Saqlash"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#1A237E"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
